<Window x:Class="WpfApp2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CipherGuard Security ChatBot – Part 3"
        Height="700" Width="1050"
        Background="#1a1a2e"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="110"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        
        <Border Grid.Row="0" Background="#16213e">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="140"/>
                </Grid.ColumnDefinitions>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text=" CipherGuard Security ChatBot"
                               FontSize="26" FontWeight="Bold"
                               Foreground="#e94560"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Your Cybersecurity Awareness Assistant"
                               FontSize="13" Foreground="#a0a0b0"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <Border Grid.Column="1" Width="90" Height="90"
                        CornerRadius="45" ClipToBounds="True"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image Source="/bot.jpeg" Stretch="UniformToFill"/>
                </Border>
            </Grid>
        </Border>

        
        <TabControl Grid.Row="1" Background="#1a1a2e"
                    BorderThickness="0"
                    Foreground="White">

            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="#16213e"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Padding" Value="16,8"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="TabBorder"
                                        Background="#16213e"
                                        Padding="16,10"
                                        Margin="2,4,2,0"
                                        CornerRadius="6,6,0,0">
                                    <ContentPresenter ContentSource="Header"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="TabBorder" Property="Background" Value="#e94560"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="TabBorder" Property="Background" Value="#0f3460"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            
            <TabItem Header=" Chat">
                <Grid Background="#1a1a2e">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="70"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" x:Name="ChatScroll"
                                  VerticalScrollBarVisibility="Auto"
                                  Margin="10">
                        <StackPanel x:Name="ChatPanel"/>
                    </ScrollViewer>

                    <Grid Grid.Row="1" Margin="10,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="UserInput"
                                 Height="48" FontSize="15"
                                 Background="#16213e" Foreground="White"
                                 CaretBrush="White"
                                 BorderBrush="#e94560" BorderThickness="2"
                                 VerticalContentAlignment="Center"
                                 Padding="10,0"
                                 Margin="0,0,8,0"
                                 KeyDown="UserInput_KeyDown"/>
                        <Button Grid.Column="1" Content="Send 📨"
                                Height="48" FontSize="15"
                                Background="#e94560" Foreground="White"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="SendButton_Click"/>
                    </Grid>
                </Grid>
            </TabItem>

            
            <TabItem Header=" Tasks">
                <Grid Background="#1a1a2e" Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="340"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    
                    <Border Grid.Column="0" Background="#16213e"
                            CornerRadius="8" Padding="16" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="➕ Add New Task" FontSize="16"
                                       FontWeight="Bold" Foreground="#e94560"
                                       Margin="0,0,0,12"/>

                            <TextBlock Text="Title *" Foreground="#a0a0b0" FontSize="12"/>
                            <TextBox x:Name="TaskTitle" Height="36" Margin="0,4,0,10"
                                     Background="#1a1a2e" Foreground="White"
                                     BorderBrush="#e94560" BorderThickness="1"
                                     Padding="8,0"/>

                            <TextBlock Text="Description *" Foreground="#a0a0b0" FontSize="12"/>
                            <TextBox x:Name="TaskDescription" Height="70" Margin="0,4,0,10"
                                     Background="#1a1a2e" Foreground="White"
                                     BorderBrush="#e94560" BorderThickness="1"
                                     Padding="8,4" TextWrapping="Wrap"
                                     AcceptsReturn="True"/>

                            <TextBlock Text="Reminder (optional)" Foreground="#a0a0b0" FontSize="12"/>
                            <TextBox x:Name="TaskReminder" Height="36" Margin="0,4,0,4"
                                     Background="#1a1a2e" Foreground="White"
                                     BorderBrush="#555" BorderThickness="1"
                                     Padding="8,0"/>
                            <TextBlock Text="e.g. 2026-07-01  or  Remind me in 7 days"
                                       Foreground="#666" FontSize="11" Margin="0,0,0,14"/>

                            <Button Content=" Save Task"
                                    Height="42" FontSize="14"
                                    Background="#e94560" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="SaveTask_Click"/>

                            <Separator Margin="0,16" Background="#333"/>

                            <Button Content=" Refresh List"
                                    Height="38" FontSize="13"
                                    Background="#0f3460" Foreground="White"
                                    BorderThickness="0" Cursor="Hand"
                                    Click="RefreshTasks_Click"/>

                            <TextBlock x:Name="TaskStatusLabel"
                                       Foreground="#4caf50" FontSize="12"
                                       Margin="0,10,0,0" TextWrapping="Wrap"/>

                            <Separator Margin="0,16" Background="#333"/>
                            <TextBlock Text="DB Connection String:"
                                       Foreground="#a0a0b0" FontSize="11"/>
                            <TextBox x:Name="ConnStringBox"
                                     Text="server=localhost;database=cybersecurity_chatbot;uid=root;pwd=;"
                                     Height="36" Margin="0,4,0,0" FontSize="10"
                                     Background="#1a1a2e" Foreground="#aaa"
                                     BorderBrush="#444" BorderThickness="1"
                                     Padding="6,0"/>
                        </StackPanel>
                    </Border>

                    
                    <Border Grid.Column="1" Background="#16213e"
                            CornerRadius="8" Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text=" Your Tasks"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="#e94560" Margin="0,0,0,8"/>

                            <ListView Grid.Row="1" x:Name="TaskListView"
                                      Background="#1a1a2e"
                                      Foreground="White"
                                      BorderThickness="0"
                                      SelectionMode="Single">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="ID" Width="40"
                                            DisplayMemberBinding="{Binding Id}"/>
                                        <GridViewColumn Header="Title" Width="160"
                                            DisplayMemberBinding="{Binding Title}"/>
                                        <GridViewColumn Header="Description" Width="200"
                                            DisplayMemberBinding="{Binding Description}"/>
                                        <GridViewColumn Header="Reminder" Width="130"
                                            DisplayMemberBinding="{Binding Reminder}"/>
                                        <GridViewColumn Header="Status" Width="80"
                                            DisplayMemberBinding="{Binding Status}"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>

                            <StackPanel Grid.Row="2" Orientation="Horizontal"
                                        Margin="0,8,0,0">
                                <Button Content=" Mark Complete"
                                        Width="150" Height="38" FontSize="13"
                                        Background="#4caf50" Foreground="White"
                                        BorderThickness="0" Cursor="Hand"
                                        Margin="0,0,8,0"
                                        Click="MarkComplete_Click"/>
                                <Button Content=" Delete Task"
                                        Width="130" Height="38" FontSize="13"
                                        Background="#e94560" Foreground="White"
                                        BorderThickness="0" Cursor="Hand"
                                        Click="DeleteTask_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            
            <TabItem Header=" Quiz">
                <Grid Background="#1a1a2e" Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    
                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock x:Name="QuizProgressLabel"
                                   Text="Press 'Start Quiz' to begin!"
                                   Foreground="#a0a0b0" FontSize="13"
                                   HorizontalAlignment="Center"/>
                        <ProgressBar x:Name="QuizProgress"
                                     Height="8" Margin="0,6,0,0"
                                     Background="#16213e"
                                     Foreground="#e94560"
                                     BorderThickness="0"
                                     Minimum="0" Maximum="12" Value="0"/>
                    </StackPanel>

                    
                    <Border Grid.Row="1" Background="#16213e"
                            CornerRadius="8" Padding="20" Margin="0,0,0,12">
                        <TextBlock x:Name="QuizQuestion"
                                   Text="Welcome to the Cybersecurity Quiz!\nTest your knowledge across phishing, passwords, safe browsing and social engineering."
                                   Foreground="White" FontSize="16"
                                   TextWrapping="Wrap" LineHeight="24"/>
                    </Border>

                    
                    <StackPanel Grid.Row="2" x:Name="AnswerPanel" Margin="0,0,0,10"/>

                    
                    <Border Grid.Row="3" x:Name="FeedbackBorder"
                            Background="#16213e" CornerRadius="8"
                            Padding="16" Margin="0,0,0,12"
                            Visibility="Collapsed">
                        <TextBlock x:Name="FeedbackText"
                                   Foreground="#4caf50" FontSize="14"
                                   TextWrapping="Wrap"/>
                    </Border>

                    
                    <StackPanel Grid.Row="4" Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <Button Content="▶ Start Quiz"
                                Width="150" Height="44" FontSize="15"
                                Background="#e94560" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                Margin="0,0,12,0"
                                Click="StartQuiz_Click"/>
                        <Button x:Name="NextQuestionBtn"
                                Content="Next ➡"
                                Width="130" Height="44" FontSize="15"
                                Background="#0f3460" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                Visibility="Collapsed"
                                Click="NextQuestion_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            
            <TabItem Header=" Activity Log">
                <Grid Background="#1a1a2e" Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text=" Recent Activity Log (last 10 actions)"
                               FontSize="16" FontWeight="Bold"
                               Foreground="#e94560" Margin="0,0,0,10"/>

                    <Border Grid.Row="1" Background="#16213e"
                            CornerRadius="8" Padding="10">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="ActivityLogPanel"/>
                        </ScrollViewer>
                    </Border>

                    <Button Grid.Row="2"
                            Content=" Clear Log"
                            Width="140" Height="38" FontSize="13"
                            Background="#555" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            HorizontalAlignment="Right"
                            Margin="0,10,0,0"
                            Click="ClearLog_Click"/>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
